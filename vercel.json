{
  "name": "vigorre-one",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html",
      "permanent": true
    },
    {
      "source": "/login",
      "destination": "/login.html",
      "permanent": true
    },
    {
      "source": "/disc",
      "destination": "/tests/disc/",
      "permanent": true
    },
    {
      "source": "/bigfive",
      "destination": "/tests/bigfive/",
      "permanent": true
    },
    {
      "source": "/ie",
      "destination": "/tests/ie/",
      "permanent": true
    },
    {
      "source": "/valores",
      "destination": "/tests/valores/",
      "permanent": true
    },
    {
      "source": "/swot",
      "destination": "/tests/swot/",
      "permanent": true
    },
    {
      "source": "/laudo",
      "destination": "/laudos/",
      "permanent": true
    },
    {
      "source": "/privacidade",
      "destination": "/politica-privacidade.html",
      "permanent": true
    },
    {
      "source": "/termos",
      "destination": "/termos-uso.html",
      "permanent": true
    },
    {
      "source": "/contato",
      "destination": "/contato.html",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@next_public_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@next_public_supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key",
    "NEXT_PUBLIC_APP_URL": "@next_public_app_url",
    "NEXT_PUBLIC_API_URL": "@next_public_api_url",
    "JWT_SECRET": "@jwt_secret",
    "GEMINI_API_KEY": "@gemini_api_key"
  }
}
