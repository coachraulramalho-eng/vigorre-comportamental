# ============================================
# VARIÁVEIS DE AMBIENTE - VIGORRE ONE™
# ============================================

# ===== SUPABASE =====
# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (pública) - usada no frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Chave de serviço (privada) - usada apenas no backend
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-aqui

# ===== APP =====
# URL da aplicação em produção
NEXT_PUBLIC_APP_URL=https://vigorre.com.br

# URL da API
NEXT_PUBLIC_API_URL=https://vigorre.com.br/api

# ===== SEGURANÇA =====
# Chave JWT para autenticação
JWT_SECRET=sua-chave-jwt-secreta-aqui

# Chave de criptografia para dados sensíveis
ENCRYPTION_KEY=sua-chave-criptografia-aqui

# ===== GOOGLE GEMINI (IA) =====
# Chave da API Gemini (opcional - se não configurada, usa modo simulado)
GEMINI_API_KEY=sua-chave-gemini-aqui

# ===== E-MAIL (SMTP) =====
# Configuração para envio de e-mails (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-ou-app-password
SMTP_FROM=contato@vigorre.com.br

# ===== MODO DE DESENVOLVIMENTO =====
# Ativar modo de desenvolvimento (true/false)
DEV_MODE=false

# Logs detalhados (true/false)
DEBUG_MODE=false
