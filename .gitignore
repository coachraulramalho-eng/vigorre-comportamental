# ============================================
# VIGORRE ONE™ - .gitignore
# ============================================

# Dependências
node_modules/
package-lock.json
yarn.lock

# Arquivos de sistema
.DS_Store
Thumbs.db
desktop.ini

# Arquivos de ambiente (NUNCA enviar para o GitHub!)
.env
.env.local
.env.*.local

# Arquivos de log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Arquivos de build
dist/
build/
out/
.next/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Arquivos temporários
*.tmp
*.temp
.cache/

# Backup
*.bak
*.backup

# Supabase
supabase/.temp/

# Arquivos de configuração local
.vscode/
.vercel/
